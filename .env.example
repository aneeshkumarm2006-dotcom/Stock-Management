# Auth.js — session/JWT signing (32+ char random string)
AUTH_SECRET=
# Canonical app URL, e.g. https://app.example.com
AUTH_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MongoDB Atlas connection string (mongodb+srv://...)
MONGODB_URI=

# Third-party market data APIs (server-side only)
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
EXCHANGE_RATE_API_KEY=

# Shared secret the Vercel Cron request must send
CRON_SECRET=

# Public app name
NEXT_PUBLIC_APP_NAME=Portfolio

# Cloudinary — file/document storage for the PM Files module.
# Free tier: 25 GB storage + 25 GB monthly bandwidth.
# Sign up at https://cloudinary.com and grab credentials from Console → Dashboard.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
